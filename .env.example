# GitHub API token (optional but recommended for higher rate limits)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Output directory for scan results (default: results)
PQC_RESULTS_DIR=results

# Where to clone repos during collect (default: system temp)
# PQC_CLONE_DIR=/tmp/pqc_clones

# Scanner state DB is stored in scanner/state.db by default (no env override)
